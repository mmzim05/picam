# PiCam UVC firmware — Buildroot defconfig
# Target: Raspberry Pi Zero 2 W (BCM2710, Cortex-A53, 64-bit)
# Base: raspberrypi3_64_defconfig

# Architecture
BR2_aarch64=y
BR2_cortex_a53=y
BR2_ARM_FPU_VFPV4=y

# Toolchain
BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y
BR2_TOOLCHAIN_BUILDROOT_WCHAR=y
BR2_GCC_VERSION_13_X=y
BR2_BINUTILS_VERSION_2_41_X=y

# Compiler cache
BR2_CCACHE=y

# System
BR2_TARGET_GENERIC_HOSTNAME="picam"
BR2_TARGET_GENERIC_ISSUE=""
BR2_TARGET_GENERIC_ROOT_PASSWD=""
BR2_TARGET_GENERIC_REMOUNT_ROOTFS_RW=n
BR2_SYSTEM_DHCP=""

# BusyBox init (faster than systemd)
BR2_INIT_BUSYBOX=y
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_BUSYBOX_SHOW_OTHERS=y

# Kernel — use Raspberry Pi fork (has camera + UVC gadget drivers)
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_GIT=y
BR2_LINUX_KERNEL_CUSTOM_REPO_URL="https://github.com/raspberrypi/linux"
BR2_LINUX_KERNEL_CUSTOM_REPO_VERSION="stable"
BR2_LINUX_KERNEL_DEFCONFIG="bcm2711"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_PICAM_PATH)/board/picam/kernel.config"
BR2_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y
BR2_LINUX_KERNEL_IMAGE_TARGET_CUSTOM=y
BR2_LINUX_KERNEL_IMAGE_TARGET_NAME="Image"
BR2_LINUX_KERNEL_DTS_SUPPORT=y
BR2_LINUX_KERNEL_INTREE_DTS_NAME="broadcom/bcm2710-rpi-zero-2-w broadcom/bcm2710-rpi-zero-2"
BR2_LINUX_KERNEL_INSTALL_TARGET=n

# Pi GPU firmware (start.elf, fixup.dat, dtb overlays)
BR2_PACKAGE_RASPBERRYPI_FIRMWARE=y

# libcamera with Raspberry Pi pipeline and IPA modules
BR2_PACKAGE_LIBCAMERA=y
BR2_PACKAGE_LIBCAMERA_IPA=y
BR2_PACKAGE_LIBCAMERA_PIPELINE_SIMPLE=n
BR2_PACKAGE_LIBCAMERA_PIPELINE_RASPBERRYPI=y

# JPEG encoding (libjpeg-turbo for fast SIMD-accelerated software encode)
BR2_PACKAGE_LIBJPEG_TURBO=y

# Our application
BR2_PACKAGE_PICAM_APP=y

# v4l-utils: provides v4l2-ctl for debugging (optional, remove for smallest image)
BR2_PACKAGE_V4L_UTILS=y

# Root filesystem: squashfs (read-only, fast mount, SD-safe)
BR2_TARGET_ROOTFS_SQUASHFS=y
BR2_TARGET_ROOTFS_SQUASHFS4_XZ=y

# No network, no SSH, no udev
BR2_PACKAGE_IFUPDOWN_SCRIPTS=n
BR2_PACKAGE_OPENSSH=n
BR2_ROOTFS_DEVICE_CREATION_STATIC=y

# Post-build / post-image scripts
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_PICAM_PATH)/board/picam/post-build.sh"
BR2_ROOTFS_POST_IMAGE_SCRIPT="$(BR2_EXTERNAL_PICAM_PATH)/board/picam/post-image.sh"

# genimage (creates the SD card .img)
BR2_PACKAGE_HOST_GENIMAGE=y
BR2_PACKAGE_HOST_DOSFSTOOLS=y
BR2_PACKAGE_HOST_MTOOLS=y

# CMake (needed to build picam-app)
BR2_PACKAGE_HOST_CMAKE=y
