# Kernel config fragment for PiCam UVC firmware
# Applied on top of bcm2711_defconfig

# USB gadget framework
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_UEVENT=y
CONFIG_USB_CONFIGFS_F_UVC=y
CONFIG_USB_CONFIGFS_F_FS=n

# dwc2 OTG controller (Pi Zero 2 W)
CONFIG_USB_DWC2=y
CONFIG_USB_DWC2_PERIPHERAL=y

# V4L2 video framework (required by both libcamera and UVC gadget)
CONFIG_VIDEO_DEV=y
CONFIG_VIDEO_V4L2=y
CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_CAMERA_SUPPORT=y

# Raspberry Pi camera stack
CONFIG_VIDEO_RASPBERRYPI_UNICAM=y
CONFIG_VIDEO_RASPBERRYPI_ISP=y

# IMX477 sensor driver
CONFIG_VIDEO_IMX477=y

# devtmpfs — kernel auto-creates /dev nodes for UVC gadget /dev/videoN etc.
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# squashfs read-only root
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_LZ4=y
CONFIG_SQUASHFS_LZO=y
CONFIG_SQUASHFS_XZ=y

# Disable unused drivers to keep kernel small
CONFIG_BT=n
CONFIG_SOUND=n
CONFIG_SND=n

# WiFi — BCM43436 on Pi Zero 2 W (brcmfmac SDIO)
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_BRCMFMAC=y
CONFIG_BRCMFMAC_SDIO=y
