#!/bin/sh
# BusyBox SysV init script for picam-app
# Runs after all other init scripts (S99)

GADGET_SCRIPT=/usr/share/picam/setup_gadget.sh
PICAM_APP=/usr/bin/picam-app
LOGFILE=/tmp/picam.log
DEBUGLOG=/tmp/gadget-setup.log

start() {
    echo "=== PiCam startup ===" > "$DEBUGLOG"

    # configfs lives under sysfs; mount in case it wasn't auto-mounted
    mount -t configfs none /sys/kernel/config 2>/dev/null || true
    echo "configfs: $(ls /sys/kernel/config/ 2>&1)" >> "$DEBUGLOG"

    echo "--- gadget setup ---" >> "$DEBUGLOG"
    if $GADGET_SCRIPT >> "$DEBUGLOG" 2>&1; then
        echo "Gadget setup: OK" >> "$DEBUGLOG"
    else
        echo "Gadget setup: FAILED (exit $?)" >> "$DEBUGLOG"
    fi

    # UDC state: not-attached | attached | powered | default | addressed | configured
    echo "--- UDC state ---" >> "$DEBUGLOG"
    for udc in /sys/class/udc/*; do
        printf 'UDC %s: %s\n' \
            "$(basename "$udc")" \
            "$(cat "$udc/state" 2>/dev/null || echo unknown)" >> "$DEBUGLOG"
    done

    echo "--- /dev/video* ---" >> "$DEBUGLOG"
    ls /dev/video* 2>/dev/null >> "$DEBUGLOG" || echo "(none)" >> "$DEBUGLOG"

    echo "--- dmesg tail ---" >> "$DEBUGLOG"
    dmesg 2>/dev/null | tail -50 >> "$DEBUGLOG"

    # Write debug log to FAT boot partition so it's readable from host PC
    mount -o remount,rw /boot 2>/dev/null || \
        mount -t vfat /dev/mmcblk0p1 /boot -o rw 2>/dev/null || true
    cp "$DEBUGLOG" /boot/picam-debug.log 2>/dev/null || true
    mount -o remount,ro /boot 2>/dev/null || true

    # Find UVC gadget video node and start the app
    UVC_DEV="/dev/$(find_uvc_dev)"
    $PICAM_APP -d "$UVC_DEV" >> $LOGFILE 2>&1 &
    mkdir -p /run
    echo $! > /run/picam.pid
}

stop() {
    if [ -f /run/picam.pid ]; then
        kill "$(cat /run/picam.pid)" 2>/dev/null || true
        rm -f /run/picam.pid
    fi
}

find_uvc_dev() {
    for dev in /dev/video*; do
        name=$(v4l2-ctl -d "$dev" --info 2>/dev/null | grep "Driver name" | awk '{print $NF}')
        if [ "$name" = "uvc_gadget" ]; then
            basename "$dev"
            return
        fi
    done
    echo "video0"
}

case "$1" in
    start)   start ;;
    stop)    stop  ;;
    restart) stop; start ;;
    *)       echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac

exit 0
